# NexaRats Inventory API Configuration
# Copy this file to .env.local for local development

# Backend API Base URL
# Local development: http://localhost:5000/api
# Production: https://api.nexarats.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# Enable/Disable Mock Data (localStorage)
# Set to 'false' to connect to the actual backend
VITE_USE_MOCKS=true

# Default password for seeded demo users (only used when DB is empty)
# Change this in production or remove entirely when using real backend auth
VITE_DEFAULT_ADMIN_PASSWORD=demo1234

# Auth Configuration (for future Auth0 / OAuth integration)
VITE_AUTH_DOMAIN=your-auth-domain.auth0.com
VITE_AUTH_CLIENT_ID=your_client_id_here

# Cloud Storage (for product images — future)
VITE_S3_BUCKET=your-bucket-name-here
